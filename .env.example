# PostgreSQL connection string
DATABASE_URL="postgres://user:password@localhost:5432/hub"

# Public origin of the deployed app (required by adapter-node for form POST/CSRF in production)
ORIGIN="http://localhost:5173"

# Password for the /admin area, and a long random secret used to sign the admin session cookie
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="generate-with: openssl rand -hex 32"

# GitHub account whose public repos are synced into the hub
GITHUB_USERNAME="kaufmann-dev"
# Optional: raises the GitHub API rate limit; sync works without it
GITHUB_TOKEN=""
